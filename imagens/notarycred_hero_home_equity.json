        "objectFit": "cover",
        "objectPosition": "center right",
        "overlay": "linear-gradient(90deg, #061B2D 0%, rgba(6,27,45,0.88) 38%, rgba(6,27,45,0.40) 68%, rgba(6,27,45,0.18) 100%)"
      }
    },
    "simulationCardImage": {
      "type": "image/illustration",
      "description": "Casa moderna iluminada à noite com ícone linear verde de residência sobreposto"
    }
  },
  "header": {
    "height": "88px",
    "background": "#0B1622",
