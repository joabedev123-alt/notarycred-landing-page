{
  "project": "NotaryCred",
  "page": "Home Equity Hero",
  "layoutReference": "hero idêntico ao print enviado: header escuro, hero em azul petróleo com imagem à direita, texto grande à esquerda, card de simulação sobreposto, benefícios em linha e bloco de confiança abaixo",
  "theme": {
    "colors": {
      "navyDark": "#071827",
      "navyHeader": "#0B1622",
      "navyOverlay": "#061B2D",
      "blueDark": "#0A2A42",
      "blueAccent": "#0EA5E9",
      "greenPrimary": "#17B85F",
      "greenLight": "#45E07A",
      "white": "#FFFFFF",
      "textMuted": "#D4DEE8",
      "textSoft": "#A8B7C6",
      "border": "rgba(255,255,255,0.18)",
