      "maxWidth": "1180px",
      "items": [
        {
          "icon": "bi-shield-check",
          "title": "Segurança jurídica",
          "description": "Processos com certificação e total conformidade legal."
        },
        {
          "icon": "bi-rocket-takeoff",
          "title": "Agilidade",
          "description": "Análise rápida e liberações eficientes."
        },
        {
          "icon": "bi-calculator",
          "title": "Flexibilidade",
          "description": "Prazos longos e parcelas que cabem no seu planejamento."
        },
        {
          "icon": "bi-people",
