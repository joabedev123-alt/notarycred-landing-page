        {
          "icon": "bi-cash-coin",
          "title": "Até 60% do valor do imóvel",
          "description": "Crédito com garantia real"
        },
        {
          "icon": "bi-shield-lock",
          "title": "Processo 100% seguro",
          "description": "Transparência e agilidade"
        }
