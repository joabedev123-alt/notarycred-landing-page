  "responsiveRules": {
    "desktop": "Header horizontal, hero em duas colunas, imagem à direita, card flutuante sobre a imagem, barra de benefícios sobreposta ao final do hero.",
    "tablet": "Reduzir título, manter duas colunas se houver espaço; card de simulação menor.",
    "mobile": "Header compacto, menu hamburguer, hero em coluna única, imagem como fundo com overlay mais escuro, botões empilhados, card de simulação abaixo do texto, benefícios em grid 1 coluna."
  },
  "implementationNotes": {
    "framework": "React + TypeScript + Tailwind CSS",
    "ui": "shadcn/ui",
    "icons": "Bootstrap Icons ou Lucide React",
    "animations": "Framer Motion com fade-up, stagger nos cards e hover suave nos botões",
    "important": "Recriar o hero o mais próximo possível da imagem enviada, mantendo cores, espaçamento, estrutura, card flutuante e barra de benefícios. Trocar apenas imagens por assets profissionais compatíveis com Home Equity/NotaryCred."
  }
